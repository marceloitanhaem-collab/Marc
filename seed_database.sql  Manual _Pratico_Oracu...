-- Script SQL para criação da tabela semente do lote de 100 produtos
CREATE TABLE produtos_oraculo (
    id SERIAL PRIMARY KEY,
    chave_busca VARCHAR(100) UNIQUE NOT NULL,
    nome VARCHAR(255) NOT NULL,
    preco_base_usd NUMERIC(10, 2) NOT NULL,
    ano_referencia INT NOT NULL,
    composicao_silicio_kg NUMERIC(6, 4) DEFAULT 0,
    composicao_cobre_kg NUMERIC(6, 4) DEFAULT 0,
    composicao_ferro_kg NUMERIC(6, 4) DEFAULT 0,
    cultura_pop TEXT,
    empresa_patrocinio VARCHAR(100),
    fato_historico TEXT,
    url_patrocinio TEXT,
    normas_tecnicas TEXT[],
    interop_medica TEXT,
    rastro_seguranca VARCHAR(100) DEFAULT 'lote_regular_verificado'
);

