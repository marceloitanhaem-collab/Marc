from flask import Flask, request, jsonify
import google.generativeai as genai
import os

app = Flask(__name__)

# Configure a chave do Gemini (o ideal é usar variáveis de ambiente)
genai.configure(api_key="SUA_CHAVE_GEMINI_AQUI")
model = genai.GenerativeModel('gemini-1.5-flash')

@app.route('/oraculo-api', methods=['POST'])
def oraculo_api():
    dados = request.json
    url_imagem = dados.get('imageUrl')
    
    # Instrução para a IA
    prompt = "Analise esta imagem, identifique o nome do produto, uma breve descrição e o preço. Responda apenas em formato JSON com as chaves: 'nome', 'descricao', 'preco'."
    
    # Processamento com Gemini (simplificado para o exemplo)
    try:
        # Aqui o Gemini processa a URL da imagem
        response = model.generate_content([prompt, url_imagem])
        return jsonify({"status": "sucesso", "dados": response.text})
    except Exception as e:
        return jsonify({"status": "erro", "mensagem": str(e)})

if __name__ == '__main__':
    app.run(port=5000)
