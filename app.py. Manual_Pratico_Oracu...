from flask import Flask, request, jsonify
import google.generativeai as genai
import os

app = Flask(__name__)

# Configuração da chave - em produção, usaremos uma variável de ambiente
genai.configure(api_key="SUA_CHAVE_GEMINI_AQUI")
model = genai.GenerativeModel('gemini-1.5-flash')

@app.route('/oraculo-api', methods=['POST'])
def oraculo_api():
    try:
        dados = request.json
        url_imagem = dados.get('imageUrl')
        
        if not url_imagem:
            return jsonify({"status": "erro", "mensagem": "Nenhuma imagem foi recebida"}), 400
        
        # O prompt estruturado para garantir que a IA devolva o que precisamos
        prompt = (
            "Analise a imagem e extraia os dados em formato JSON. "
            "Use estas chaves: 'nome_produto', 'descricao', 'preco'. "
            "Se não encontrar o preço, coloque '0.00'."
        )
        
        response = model.generate_content([prompt, url_imagem])
        
        # Aqui o resultado vai chegar organizado
        return jsonify({"status": "sucesso", "dados": response.text})
        
    except Exception as e:
        return jsonify({"status": "erro", "mensagem": str(e)}), 500

if __name__ == '__main__':
    app.run(debug=True)
